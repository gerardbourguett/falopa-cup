---
import styles from './MatchCard.module.css';

interface Club {
  id: string;
  name: string;
  shortName: string;
  logo: string;
}

interface Props {
  match: {
    type: 'seeding' | 'match';
    date: Date;
    competition?: string;
    reason?: string;
    holderId?: string;
    challengerId?: string;
    scoreHolder?: number;
    scoreChallenger?: number;
    penalties?: { holder: number; challenger: number };
    newHolderId?: string;
  };
  clubs: Map<string, Club>;
  index?: number;
  accentColor?: 'gold' | 'burgundy';
}

const { match, clubs, index = 0, accentColor = 'gold' } = Astro.props;

function getClub(id?: string) {
  return id ? clubs.get(id) : undefined;
}

const holder = getClub(match.holderId);
const challenger = getClub(match.challengerId);
const newHolder = getClub(match.newHolderId);

const holderWon = match.newHolderId === match.holderId;
const challengerWon = match.newHolderId !== match.holderId && match.newHolderId === match.challengerId;
const isDraw = match.scoreHolder === match.scoreChallenger && !match.penalties;
const defaultAccentColor = accentColor === 'gold' ? 'var(--color-liga-primera)' : 'var(--color-liga-ascenso)';

// Detect competition type
const isLigaPrimera = match.competition?.includes('Liga de Primera');
const isLigaAscenso = match.competition?.includes('Liga de Ascenso');
const compColor = isLigaPrimera
  ? 'var(--color-liga-primera)'
  : isLigaAscenso
    ? 'var(--color-liga-ascenso)'
    : defaultAccentColor;

const dateStr = match.date.toLocaleDateString('es-CL', {
  day: 'numeric',
  month: 'short',
});
---

<article
  class:list={[
    styles.matchCard,
    { [styles.titleChange]: challengerWon, [styles.seedingCard]: match.type === 'seeding' },
  ]}
  style={`--comp-color: ${compColor}; --delay: ${index * 0.02}s`}
>
  {match.type === 'seeding' ? (
    <div>
      <div class={styles.seedingHeader}>
        <span class={styles.seedingBadge}>SEMBRADO</span>
        <time class={styles.matchDate}>{dateStr}</time>
      </div>
      <div class={styles.seedingBody}>
        <div class={styles.seedingTeam}>
          {holder?.logo && (
            <img src={holder.logo} alt={holder.name} class={styles.teamLogo} width="32" height="32" />
          )}
          <span class={styles.teamName}>{holder?.name || match.holderId}</span>
        </div>
        {match.reason && <span class={styles.seedingReason}>{match.reason}</span>}
      </div>
    </div>
  ) : (
    <div>
      <div class={styles.matchHeader}>
        <time class={styles.matchDate}>{dateStr}</time>
        {match.competition && (
          <span class={styles.matchCompetition}>
            {match.competition.toUpperCase()}
          </span>
        )}
        {challengerWon && (
          <span class:list={[styles.statusBadge, styles.changeBadge]}>CAMBIO</span>
        )}
        {holderWon && !isDraw && !challengerWon && (
          <span class:list={[styles.statusBadge, styles.retainBadge]}>DEFENDE</span>
        )}
        {isDraw && (
          <span class:list={[styles.statusBadge, styles.drawBadge]}>EMPATE</span>
        )}
      </div>

      <div class={styles.matchBody}>
        <div class:list={[styles.team, styles.teamHome, { [styles.winner]: holderWon && !isDraw }]}> 
          {holder?.logo && (
            <img src={holder.logo} alt={holder.name} class={styles.teamLogo} width="32" height="32" />
          )}
          <span class={styles.teamName}>{holder?.name || match.holderId}</span>
          <span class={styles.teamNameShort}>{holder?.shortName || holder?.name || match.holderId}</span>
        </div>

        <div class={styles.scoreBlock}>
          <div class={styles.scoreRow}>
            <span class={styles.scoreboard}>{match.scoreHolder}</span>
            <span class={styles.scoreDash}>-</span>
            <span class={styles.scoreboard}>{match.scoreChallenger}</span>
          </div>
          {match.penalties && (
            <span class={styles.penalties}>({match.penalties.holder}-{match.penalties.challenger} pen)</span>
          )}
        </div>

        <div class:list={[styles.team, styles.teamAway, { [styles.winner]: challengerWon }]}> 
          <span class={styles.teamName}>{challenger?.name || match.challengerId}</span>
          <span class={styles.teamNameShort}>{challenger?.shortName || challenger?.name || match.challengerId}</span>
          {challenger?.logo && (
            <img src={challenger.logo} alt={challenger.name} class={styles.teamLogo} width="32" height="32" />
          )}
        </div>
      </div>

      {challengerWon && newHolder && (
        <div class={styles.newHolder}>
          <span class={styles.newHolderLabel}>Nuevo Campeón:</span>
          {newHolder.logo && (
            <img src={newHolder.logo} alt="" width="20" height="20" class={styles.teamLogoSm} />
          )}
          <span class={styles.newHolderName}>{newHolder.name}</span>
        </div>
      )}
    </div>
  )}
</article>

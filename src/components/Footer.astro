---
const today = new Date();
import styles from "./Footer.module.css";
---

<footer class={styles.footer}>
  <div class={styles.content}>
    <div class={styles.brand}>
      <div class={styles.brandIcon}>
        <img src="/favicon.png" alt="" class={styles.brandLogo} aria-hidden="true" />
      </div>
      <div class={styles.brandText}>
        <span class={styles.brandTitle}>FALOPA CUP</span>
        <span class={styles.brandSubtitle}>Campeonato No Oficial desde 2025</span>
      </div>
    </div>

    <p class={styles.copy}>
      © {today.getFullYear()} Falopa Cup. Ningún derecho reservado.
    </p>
  </div>
</footer>

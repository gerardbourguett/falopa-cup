---
interface Club {
  id: string;
  name: string;
  shortName: string;
  logo: string;
}

interface Props {
  allMatches: any[];
  clubs: Map<string, Club>;
  accentColor?: "gold" | "burgundy";
  currentHolderId?: string;
}

const {
  allMatches,
  clubs,
  accentColor = "gold",
  currentHolderId,
} = Astro.props;

interface ClubStats {
  id: string;
  reigns: number;
  defenses: number;
  conquests: number;
  losses: number;
  matchesAsHolder: number;
}

const statsMap = new Map<string, ClubStats>();

function ensure(id: string): ClubStats {
  if (!statsMap.has(id)) {
    statsMap.set(id, {
      id,
      reigns: 0,
      defenses: 0,
      conquests: 0,
      losses: 0,
      matchesAsHolder: 0,
    });
  }
  return statsMap.get(id)!;
}

for (const m of allMatches) {
  if (m.type === "seeding" && m.holderId) {
    const s = ensure(m.holderId);
    s.reigns++;
  }
  if (m.type === "match") {
    if (m.holderId) {
      const holder = ensure(m.holderId);
      holder.matchesAsHolder++;
      if (m.newHolderId === m.holderId) {
        holder.defenses++;
      } else if (m.newHolderId && m.newHolderId !== m.holderId) {
        holder.losses++;
        const winner = ensure(m.newHolderId);
        winner.conquests++;
        winner.reigns++;
      }
    }
  }
}

const ranked = [...statsMap.values()].sort((a, b) => {
  if (b.reigns !== a.reigns) return b.reigns - a.reigns;
  if (b.defenses !== a.defenses) return b.defenses - a.defenses;
  return b.conquests - a.conquests;
});

function getClub(id: string) {
  return clubs.get(id);
}

const isGold = accentColor === "gold";
const accent = isGold
  ? "var(--color-liga-primera)"
  : "var(--color-liga-ascenso)";
---

<section class="palmares">
  <div class="palmares-header">
    <div class="palmares-label">PALMARES</div>
    <div class="palmares-count">
      {ranked.length} EQUIPOS
    </div>
  </div>

  <div class="table-wrapper">
    <table class="palmares-table">
      <thead>
        <tr>
          <th class="th-pos">#</th>
          <th class="th-club">EQUIPO</th>
          <th class="th-num">TITULOS</th>
          <th class="th-num">CONQUISTAS</th>
          <th class="th-num">DEFENSAS</th>
          <th class="th-num">PERDIDAS</th>
          <th class="th-num">PJ</th>
        </tr>
      </thead>
      <tbody>
        {
          ranked.map((stat, i) => {
            const club = getClub(stat.id);
            const isCurrentHolder = stat.id === currentHolderId;
            return (
              <tr
                class:list={{
                  "row-top": i === 0,
                  "current-holder": isCurrentHolder,
                }}
              >
                <td class="td-pos">{i + 1}</td>
                <td class="td-club">
                  {club?.logo && (
                    <img
                      src={club.logo}
                      alt=""
                      width="20"
                      height="20"
                      class="club-logo"
                    />
                  )}
                  <span class="club-name">
                    {club?.shortName || club?.name || stat.id}
                  </span>
                  {isCurrentHolder && <span class="holder-badge">CAMPEON</span>}
                </td>
                <td class="td-num td-reigns">{stat.reigns}</td>
                <td class="td-num">{stat.conquests}</td>
                <td class="td-num">{stat.defenses}</td>
                <td class="td-num">{stat.losses}</td>
                <td class="td-num">{stat.matchesAsHolder}</td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>
</section>

<style {accent: accent }}>
  .palmares {
    margin: 2rem 0;
  }

  .palmares-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding: 0.75rem 1rem;
    background: var(--accent);
    color: var(--color-text-primary);
  }

  .palmares-label {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-text-primary);
  }

  .palmares-count {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .table-wrapper {
    overflow-x: auto;
  }

  .palmares-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--color-bg-secondary);
    border: 2px solid var(--accent);
  }

  .palmares-table thead {
    background: var(--color-bg-primary);
  }

  .palmares-table th {
    font-family: var(--font-display);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    padding: 0.6rem 0.75rem;
    text-align: left;
    border-bottom: 2px solid var(--accent);
    white-space: nowrap;
  }

  .th-num {
    text-align: center !important;
  }

  .th-pos {
    width: 40px;
    text-align: center !important;
  }

  .palmares-table td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--color-bg-elevated);
    font-family: var(--font-body);
    font-size: 0.85rem;
  }

  .palmares-table tbody tr:last-child td {
    border-bottom: none;
  }

  .palmares-table tbody tr:hover {
    background: var(--color-bg-tertiary);
  }

  .row-top {
    background: var(--color-bg-tertiary);
  }

  /* Current holder highlight */
  .current-holder {
    background: var(--color-holder-bg) !important;
    border-left: 4px solid var(--color-holder);
  }

  .current-holder td {
    border-color: var(--color-holder);
  }

  .td-pos {
    text-align: center;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .row-top .td-pos {
    color: var(--accent);
    font-size: 1rem;
  }

  .current-holder .td-pos {
    color: var(--color-holder);
  }

  .td-club {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .club-logo {
    border: 1px solid var(--color-bg-elevated);
    flex-shrink: 0;
  }

  .club-name {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .holder-badge {
    font-family: var(--font-display);
    font-size: 0.55rem;
    font-weight: 700;
    color: var(--color-holder);
    border: 1px solid var(--color-holder);
    padding: 0.1rem 0.3rem;
    margin-left: 0.5rem;
  }

  .td-num {
    text-align: center;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .td-reigns {
    color: var(--color-text-primary);
    font-weight: 700;
  }

  .row-top .td-reigns {
    color: var(--accent);
  }

  .current-holder .td-reigns {
    color: var(--color-holder);
  }

  @media (max-width: 600px) {
    .palmares-header {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }

    .palmares-table th {
      font-size: 0.6rem;
      padding: 0.4rem;
    }

    .palmares-table td {
      padding: 0.4rem;
      font-size: 0.75rem;
    }

    .club-logo {
      width: 16px;
      height: 16px;
    }

    .holder-badge {
      display: none;
    }
  }
</style>

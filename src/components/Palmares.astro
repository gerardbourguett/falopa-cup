---
import styles from './Palmares.module.css';

interface Club {
  id: string;
  name: string;
  shortName: string;
  logo: string;
}

interface Props {
  allMatches: any[];
  clubs: Map<string, Club>;
  accentColor?: "gold" | "burgundy";
  currentHolderId?: string;
}

const {
  allMatches,
  clubs,
  accentColor = "gold",
  currentHolderId,
} = Astro.props;

interface ClubStats {
  id: string;
  reigns: number;
  defenses: number;
  conquests: number;
  losses: number;
  matchesAsHolder: number;
}

const statsMap = new Map<string, ClubStats>();

function ensure(id: string): ClubStats {
  if (!statsMap.has(id)) {
    statsMap.set(id, {
      id,
      reigns: 0,
      defenses: 0,
      conquests: 0,
      losses: 0,
      matchesAsHolder: 0,
    });
  }
  return statsMap.get(id)!;
}

for (const m of allMatches) {
  if (m.type === "seeding" && m.holderId) {
    const s = ensure(m.holderId);
    s.reigns++;
  }
  if (m.type === "match") {
    if (m.holderId) {
      const holder = ensure(m.holderId);
      holder.matchesAsHolder++;
      if (m.newHolderId === m.holderId) {
        holder.defenses++;
      } else if (m.newHolderId && m.newHolderId !== m.holderId) {
        holder.losses++;
        const winner = ensure(m.newHolderId);
        winner.conquests++;
        winner.reigns++;
      }
    }
  }
}

const ranked = [...statsMap.values()].sort((a, b) => {
  if (b.reigns !== a.reigns) return b.reigns - a.reigns;
  if (b.defenses !== a.defenses) return b.defenses - a.defenses;
  return b.conquests - a.conquests;
});

function getClub(id: string) {
  return clubs.get(id);
}

const isGold = accentColor === "gold";
const accent = isGold
  ? "var(--color-liga-primera)"
  : "var(--color-liga-ascenso)";
---

<section class={styles.palmares} style={`--accent: ${accent}`}>
  <div class={styles.header}>
    <div class={styles.label}>PALMARES</div>
    <div class={styles.count}>
      {ranked.length} EQUIPOS
    </div>
  </div>

  <div class={styles.tableWrapper}>
    <table class={styles.table}>
      <thead>
        <tr>
          <th class={styles.positionHeader}>#</th>
          <th>EQUIPO</th>
          <th class={styles.numberHeader}>TITULOS</th>
          <th class={styles.numberHeader}>CONQUISTAS</th>
          <th class={styles.numberHeader}>DEFENSAS</th>
          <th class={styles.numberHeader}>PERDIDAS</th>
          <th class={styles.numberHeader}>PJ</th>
        </tr>
      </thead>
      <tbody>
        {
          ranked.map((stat, i) => {
            const club = getClub(stat.id);
            const isCurrentHolder = stat.id === currentHolderId;
            return (
              <tr
                class:list={{
                  [styles.topRow]: i === 0,
                  [styles.currentHolder]: isCurrentHolder,
                }}
              >
                <td class={styles.position}>{i + 1}</td>
                <td class={styles.clubCell}>
                  {club?.logo && (
                    <img
                      src={club.logo}
                      alt=""
                      width="20"
                      height="20"
                      class={styles.clubLogo}
                    />
                  )}
                  <span class={styles.clubName}>
                    {club?.shortName || club?.name || stat.id}
                  </span>
                  {isCurrentHolder && <span class={styles.holderBadge}>CAMPEON</span>}
                </td>
                <td class:list={[styles.number, styles.reigns]}>{stat.reigns}</td>
                <td class={styles.number}>{stat.conquests}</td>
                <td class={styles.number}>{stat.defenses}</td>
                <td class={styles.number}>{stat.losses}</td>
                <td class={styles.number}>{stat.matchesAsHolder}</td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>
</section>

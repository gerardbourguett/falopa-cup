---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import { SITE_TITLE } from '../../consts';
import {
  getClubAccentColor,
  getEntryTypeSportLabel,
} from '../../lib/tournaments/conference-league-sudamericana/club-visuals';

const entries = await getCollection('conference-league-sudamericana');

const clubsDoc = entries.find((e) => e.data.kind === 'clubs')?.data as any;
const stageDoc = entries.find((e) => e.data.kind === 'stage')?.data as any;
const groupsDoc = entries.find((e) => e.data.kind === 'groups')?.data as any;
const windowCutDoc = entries.find((e) => e.data.kind === 'window-cut')?.data as any;

const seeds: any[] = clubsDoc?.seeds || [];
const groups: any[] = groupsDoc?.groups || [];
const roundWindows: any[] = groupsDoc?.roundWindows || [];
const seedByIdWiki = new Map<string, any>(seeds.map((s: any) => [s.clubId, s]));
const preliminaryTies: any[] = stageDoc?.preliminaryTies || [];

const countryNames: Record<string, string> = {
  AR: 'Argentina',
  BO: 'Bolivia',
  BR: 'Brasil',
  CL: 'Chile',
  CO: 'Colombia',
  EC: 'Ecuador',
  PY: 'Paraguay',
  PE: 'Perú',
  UY: 'Uruguay',
  VE: 'Venezuela',
};

const countryOrder = ['AR', 'BO', 'BR', 'CL', 'CO', 'EC', 'PE', 'PY', 'UY', 'VE'];

function flag(country: string) {
  return `fi fi-${String(country || '').toLowerCase()}`;
}

function entryLabel(type: string) {
  switch (type) {
    case 'libertadores-f2': return 'Lib. F2';
    case 'libertadores-f1': return 'Lib. F1';
    case 'sudamericana-f1': return 'Sud. F1';
    default: return 'Base';
  }
}

function entryLabelLong(type: string) {
  switch (type) {
    case 'libertadores-f2': return 'Eliminado Copa Libertadores (Fase 2)';
    case 'libertadores-f1': return 'Eliminado Copa Libertadores (Fase 1)';
    case 'sudamericana-f1': return 'Eliminado Copa Sudamericana (Fase 1)';
    default: return 'Cupo base de liga nacional';
  }
}

function resolvedByLabel(r: string) {
  switch (r) {
    case 'fantasy-score': return 'Diferencia fantasy';
    case 'card-deductions': return 'Menos tarjetas';
    case 'goals-for': return 'Más goles marcados';
    case 'away-condition': return 'Condición visita';
    case 'conmebol-rank': return 'Coeficiente CONMEBOL';
    case 'administrative': return 'Sorteo administrativo';
    default: return r;
  }
}

// By country breakdown
const byCountry: Record<string, { base: number; libF1: number; libF2: number; sudF1: number; clubs: any[] }> = {};
for (const s of seeds) {
  if (!byCountry[s.country]) byCountry[s.country] = { base: 0, libF1: 0, libF2: 0, sudF1: 0, clubs: [] };
  byCountry[s.country].clubs.push(s);
  if (s.entryType === 'base') byCountry[s.country].base++;
  else if (s.entryType === 'libertadores-f1') byCountry[s.country].libF1++;
  else if (s.entryType === 'libertadores-f2') byCountry[s.country].libF2++;
  else if (s.entryType === 'sudamericana-f1') byCountry[s.country].sudF1++;
}

// Direct qualifiers
const leagueDirect = seeds.filter((s) => s.allocationCategory === 'league-direct').sort((a, b) => a.conmebolRank - b.conmebolRank);
const coeffDirect = seeds.filter((s) => s.allocationCategory === 'coefficient-direct').sort((a, b) => (b.conmebolCoefficient ?? 0) - (a.conmebolCoefficient ?? 0));

// Preliminary pots
const pot1 = seeds.filter((s) => s.allocationCategory === 'preliminary-pot-1').sort((a, b) => a.conmebolRank - b.conmebolRank);
const pot2 = seeds.filter((s) => s.allocationCategory === 'preliminary-pot-2').sort((a, b) => a.conmebolRank - b.conmebolRank);

// Window-cut lookup
const wcByClub = new Map<string, any>(
  (windowCutDoc?.entries || []).map((e: any) => [e.clubId, e] as [string, any])
);

// Build enriched ties
const enrichedTies = preliminaryTies.map((tie: any) => {
  const seedA = seeds.find((s) => s.clubId === tie.clubAId);
  const seedB = seeds.find((s) => s.clubId === tie.clubBId);
  const wcA = wcByClub.get(tie.clubAId);
  const wcB = wcByClub.get(tie.clubBId);
  const isWinnerA = tie.winnerClubId === tie.clubAId;
  const isWinnerB = tie.winnerClubId === tie.clubBId;
  return { tie, seedA, seedB, wcA, wcB, isWinnerA, isWinnerB };
});

function scoreBreakdownText(wc: any): string {
  if (!wc || wc.status !== 'ok') return 'sin partido en ventana → 0';
  const gf = Number(wc.goalsFor ?? 0);
  const ga = Number(wc.goalsAgainst ?? 0);
  const isWin = gf > ga;
  const isDraw = gf === ga;
  const isLoss = gf < ga;
  const base = isWin ? 3 : isDraw ? 1 : 0;
  const cleanSheet = ga === 0 ? 1 : 0;
  const margin = isWin ? Math.max(0, (gf - ga) - 1) : 0;
  const wideLoss = isLoss && ga - gf >= 3 ? -1 : 0;
  const yellowPenalty = -(Number(wc.yellowCards ?? 0) * 0.25);
  const redPenalty = -(Number(wc.redCards ?? 0));
  const total = base + cleanSheet + margin + wideLoss + yellowPenalty + redPenalty;
  const parts: string[] = [`base ${base}`];
  if (cleanSheet) parts.push('+1 arco en cero');
  if (margin > 0) parts.push(`+${margin} margen (${gf - ga} goles)`);
  if (wideLoss) parts.push('-1 derrota amplia');
  if (yellowPenalty < 0) parts.push(`${yellowPenalty} amarillas`);
  if (redPenalty < 0) parts.push(`${redPenalty} rojas`);
  parts.push(`= ${total}`);
  return parts.join(' · ');
}
---

<Layout
  title={`Wiki — Conference League Sudamericana 2026 — ${SITE_TITLE}`}
  description="Historia, participantes, clasificados, fase previa y formato de grupos — edición 2026"
  currentPath="/conference-league-sudamericana/wiki"
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Conference League Sudamericana · Edición 2026</p>
      <h1>Wiki del torneo</h1>
      <p>Historia, estructura, participantes y resultados de la fase previa.</p>
    </div>
  </section>

  <div class="container page-nav-strip">
    <a href="/conference-league-sudamericana/wiki" class="page-nav-tab active" aria-current="page">Wiki</a>
    <a href="/conference-league-sudamericana" class="page-nav-tab">Resultados</a>
  </div>

  <main class="container page-main">

    <!-- HISTORIA -->
    <section class="block" id="historia">
      <h2>Historia del torneo</h2>
      <div class="prose-block">
        <p>
          El <strong>14 de noviembre de 2025</strong>, en una sesión extraordinaria del Consejo Superior
          de CONMEBOL celebrada en Luque, Paraguay, nació oficialmente el tercer torneo continental
          sudamericano: la <strong>Conference League Sudamericana</strong>. La votación fue
          unánime: diez federaciones, diez manos levantadas, una sola certeza — el fútbol del continente
          necesitaba expandirse.
        </p>
        <p>
          La idea había madurado durante años en los pasillos de la burocracia futbolística. Bolivia
          presentó el primer anteproyecto en 2023, argumentando que la mitad de los campeones nacionales
          sudamericanos jamás disputaban una fase de grupos continental. Ecuador y Paraguay respaldaron
          la propuesta. Argentina y Brasil, inicialmente escépticos ante la posible dilución de la
          marca Libertadores, terminaron cediendo cuando se garantizó que el nuevo torneo no
          solaparía fechas ni afectaría el ingreso televisivo de las competencias principales.
        </p>
        <p>
          La <strong>novedad disruptiva</strong> fue el formato <em>fantasy por ventanas</em>.
          En lugar de viajes, estadios neutrales y logística imposible para clubes pequeños, cada
          equipo compite usando sus resultados reales en ligas locales dentro de períodos
          definidos. Un partido en Cochabamba, otro en Asunción, otro en Montevideo — todos
          transformados en puntos bajo la misma tabla: victoria tres puntos, empate uno, y bonos
          que premia la contundencia defensiva y ofensiva. El fútbol cotidiano, elevado a escenario continental.
        </p>
        <p>
          La primera edición, <strong>2026</strong>, reunió a <strong>53 clubes</strong>
          de diez países. Ídolos históricos como Colo-Colo, Atlético Nacional y Nacional de
          Uruguay comparten competencia con recién llegados al escenario internacional como
          Los Chankas de Perú, Sportivo Ameliano de Paraguay o GV San José de Bolivia.
          Una igualdad de condiciones que el viejo fútbol continental jamás había conocido.
        </p>
        <p>
          Quedará en los libros como el año en que el fútbol sudamericano se democratizó.
        </p>
      </div>
    </section>

    <!-- SISTEMA DE PUNTUACIÓN -->
    <section class="block" id="puntuacion">
      <h2>Sistema de puntuación</h2>
      <p class="criterion-note">
        Cada club usa <strong>un partido real</strong> en la ventana asignada (liga local o copa nacional).
        Ese resultado se convierte en puntos fantasy según estas reglas:
      </p>
      <div class="scoring-grid">
        <div class="score-group">
          <h3>Resultado base</h3>
          <ul class="score-rule-list">
            <li><span class="score-badge win">+3</span> Victoria</li>
            <li><span class="score-badge draw">+1</span> Empate</li>
            <li><span class="score-badge loss">0</span> Derrota</li>
          </ul>
        </div>
        <div class="score-group">
          <h3>Bonificaciones</h3>
          <ul class="score-rule-list">
            <li><span class="score-badge bonus">+1</span> Arco en cero (goalsAgainst = 0)</li>
            <li><span class="score-badge bonus">+1</span> Victoria por 2 goles de diferencia</li>
            <li><span class="score-badge bonus">+2</span> Victoria por 3 goles de diferencia</li>
            <li><span class="score-badge bonus">+N−1</span> Victoria por N goles de diferencia (progresivo)</li>
          </ul>
        </div>
        <div class="score-group">
          <h3>Penalizaciones</h3>
          <ul class="score-rule-list">
            <li><span class="score-badge penalty">−1</span> Derrota por 3+ goles de diferencia</li>
            <li><span class="score-badge penalty">−0.25</span> Por cada tarjeta amarilla</li>
            <li><span class="score-badge penalty">−1</span> Por cada tarjeta roja</li>
          </ul>
        </div>
        <div class="score-group">
          <h3>Caso especial</h3>
          <ul class="score-rule-list">
            <li><span class="score-badge nomatch">0</span> Sin partido en ventana (no-match)</li>
          </ul>
        </div>
      </div>
      <p class="criterion-note" style="margin-top: 0.75rem;">
        <strong>Desempate entre clubes con igual total:</strong>
        menos tarjetas acumuladas → más goles marcados → condición visita → menor coeficiente CONMEBOL → sorteo administrativo.
      </p>
    </section>

    <!-- PARTICIPANTES POR PAÍS -->
    <section class="block" id="participantes">
      <h2>Participantes por país</h2>
      <p class="criterion-note">
        53 clubes de 10 países. Cada asociación recibe cupos según su posición en el
        <strong>ranking CONMEBOL</strong>. Los clubes eliminados tempranamente de Libertadores
        y Sudamericana son redirigidos a esta competencia.
      </p>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>País</th>
              <th>Total</th>
              <th>Base</th>
              <th>Lib. F1</th>
              <th>Lib. F2</th>
              <th>Sud. F1</th>
              <th>Clubes</th>
            </tr>
          </thead>
          <tbody>
            {countryOrder.map((cc) => {
              const row = byCountry[cc];
              if (!row) return null;
              return (
                <tr>
                  <td>
                    <span class="inline-club">
                      <span class:list={['club-flag-icon', flag(cc)]} aria-hidden="true"></span>
                      <strong>{countryNames[cc]}</strong>
                    </span>
                  </td>
                  <td><strong>{row.clubs.length}</strong></td>
                  <td>{row.base || '—'}</td>
                  <td>{row.libF1 || '—'}</td>
                  <td>{row.libF2 || '—'}</td>
                  <td>{row.sudF1 || '—'}</td>
                  <td>
                    <span class="club-tags">
                      {row.clubs.sort((a: any, b: any) => a.conmebolRank - b.conmebolRank).map((s: any) => (
                        <span
                          class="club-tag"
                          title={`${s.name} · ${entryLabelLong(s.entryType)} · Rank #${s.conmebolRank}`}
                          style={`--accent: ${getClubAccentColor(s.clubId)}`}
                        >
                          {s.name}
                        </span>
                      ))}
                    </span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      <div class="entry-legend">
        <span><strong>Base</strong>: mejor clasificado de liga nacional</span>
        <span><strong>Lib. F1/F2</strong>: eliminado en fase 1 o 2 de Copa Libertadores</span>
        <span><strong>Sud. F1</strong>: eliminado en fase 1 de Copa Sudamericana</span>
      </div>
    </section>

    <!-- CLASIFICADOS DIRECTOS -->
    <section class="block" id="directos">
      <h2>Clasificados directos a fase principal</h2>
      <p class="criterion-note">
        Once clubes acceden directamente a la fase de grupos sin pasar por la previa.
        Ninguno es campeón de liga —  esos puestos clasifican a Libertadores o Sudamericana.
        Son los equipos que <strong>obtuvieron la mejor posición de liga disponible para Conference League</strong>:
        el cupo que queda libre después de asignar los lugares de Libertadores y Sudamericana.
        <br /><br />
        <strong>8 por cupo de liga</strong>: la mejor ubicación de su asociación que no los clasifica
        a ninguna otra copa. · <strong>3 por coeficiente CONMEBOL</strong>: los tres con mayor coeficiente
        histórico del grupo de participantes sin acceso directo de liga (transferidos de Libertadores/Sudamericana).
      </p>

      <div class="direct-grid">
        <div class="direct-group">
          <h3>Por cupo de liga <span class="badge badge-green">8 clubes</span></h3>
          <ul class="club-list">
            {leagueDirect.map((s: any) => (
              <li class="club-row club-accent" style={`--club-accent: ${getClubAccentColor(s.clubId)}`}>
                <span class:list={['club-flag-icon', flag(s.country)]} aria-hidden="true"></span>
                <span class="club-name-main">{s.name}</span>
                <span class="club-country-tag">{countryNames[s.country]}</span>
                <small>Rank #{s.conmebolRank}</small>
              </li>
            ))}
          </ul>
        </div>

        <div class="direct-group">
          <h3>Por coeficiente CONMEBOL <span class="badge badge-gold">3 clubes</span></h3>
          <ul class="club-list">
            {coeffDirect.map((s: any) => (
              <li class="club-row club-accent" style={`--club-accent: ${getClubAccentColor(s.clubId)}`}>
                <span class:list={['club-flag-icon', flag(s.country)]} aria-hidden="true"></span>
                <span class="club-name-main">{s.name}</span>
                <span class="club-country-tag">{countryNames[s.country]}</span>
                <small>{s.coefficientLabel} pts · {getEntryTypeSportLabel(s.entryType)}</small>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- FASE PREVIA -->
    <section class="block" id="fase-previa">
      <h2>Fase previa</h2>
      <p class="criterion-note">
        42 clubes disputan 21 llaves (Bombo 1 vs Bombo 2). El ganador de cada llave avanza
        a la fase principal junto con los 11 clasificados directos, completando los 32 equipos
        de la fase de grupos.
      </p>
      <p class="criterion-note">
        La clasificación se determina por el <strong>puntaje fantasy de ventana</strong>:
        cada club usa su mejor partido real en la ventana definida. En caso de empate: tarjetas
        acumuladas → goles marcados → condición visita → coeficiente CONMEBOL → sorteo administrativo.
      </p>

      <!-- BOMBOS -->
      <div class="pots-section" id="bombos">
        <div class="pots-grid">
          <div class="pot-card block-inner">
            <h3>Bombo 1 <span class="badge badge-blue">21 clubes</span></h3>
            <p class="criterion-note">Clubes con mayor coeficiente CONMEBOL del grupo de previa.</p>
            <ul class="club-list">
              {pot1.map((s: any) => (
                <li class="club-row club-accent" style={`--club-accent: ${getClubAccentColor(s.clubId)}`}>
                  <span class:list={['club-flag-icon', flag(s.country)]} aria-hidden="true"></span>
                  <div class="club-row-body">
                    <span class="club-name-main">{s.name}</span>
                    <span class="club-meta-line">{entryLabel(s.entryType)} · {s.coefficientLabel} pts</span>
                  </div>
                  <small>#{s.conmebolRank}</small>
                </li>
              ))}
            </ul>
          </div>

          <div class="pot-card block-inner">
            <h3>Bombo 2 <span class="badge badge-gray">21 clubes</span></h3>
            <p class="criterion-note">Clubes con menor coeficiente CONMEBOL del grupo de previa.</p>
            <ul class="club-list">
              {pot2.map((s: any) => (
                <li class="club-row club-accent" style={`--club-accent: ${getClubAccentColor(s.clubId)}`}>
                  <span class:list={['club-flag-icon', flag(s.country)]} aria-hidden="true"></span>
                  <div class="club-row-body">
                    <span class="club-name-main">{s.name}</span>
                    <span class="club-meta-line">{entryLabel(s.entryType)} · {s.coefficientLabel} pts</span>
                  </div>
                  <small>#{s.conmebolRank}</small>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <!-- EMPAREJAMIENTOS -->
      <h3 class="subsection-title" id="emparejamientos">Emparejamientos y resultados</h3>
      <p class="criterion-note">
        Ventana de puntuación: <strong>{windowCutDoc?.windowStart || '—'}</strong> —
        <strong>{windowCutDoc?.windowEnd || '—'}</strong>.
        Cada club usa el partido real que cayó en esa ventana para calcular su total fantasy.
      </p>

      <div class="ties-list">
        {enrichedTies.map(({ tie, seedA, seedB, wcA, wcB, isWinnerA, isWinnerB }: any) => (
          <article class="tie-article">
            <header class="tie-article-header">
              <span class="tie-id">{tie.id}</span>
              <span class="tie-resolved-badge">{resolvedByLabel(tie.resolvedBy)}</span>
            </header>

            <!-- Club A -->
            <div class:list={['tie-club-row', isWinnerA && 'winner']}>
              <div class="tie-club-identity">
                <span class:list={['club-flag-icon', flag(seedA?.country)]} aria-hidden="true"></span>
                <span class="tie-club-name">{seedA?.name || tie.clubAId}</span>
                <span class="tie-entry-badge">{entryLabel(seedA?.entryType || 'base')}</span>
              </div>
              <div class="tie-club-match">
                {wcA?.status === 'ok' ? (
                  <span class="tie-match-detail">
                    {wcA.goalsFor}-{wcA.goalsAgainst}
                    <span class="tie-ha">{wcA.homeAway === 'home' ? 'LOCAL' : 'VISITA'}</span>
                    vs {wcA.opponent}
                    <span class="tie-match-comp">{wcA.competition} · {wcA.sourceDate}</span>
                    {(wcA.yellowCards !== null && wcA.yellowCards !== undefined) && (
                      <span class="tie-cards">
                        {wcA.yellowCards > 0 && <span class="card card-yellow" title="Amarillas">🟨 {wcA.yellowCards}</span>}
                        {wcA.redCards > 0 && <span class="card card-red" title="Rojas">🟥 {wcA.redCards}</span>}
                      </span>
                    )}
                  </span>
                ) : (
                  <span class="tie-no-match">sin partido en ventana</span>
                )}
              </div>
              <div class="tie-breakdown">{scoreBreakdownText(wcA)}</div>
              <div class="tie-score-chip" data-winner={isWinnerA ? 'true' : 'false'}>
                {tie.scoreA}
              </div>
            </div>

            <!-- Club B -->
            <div class:list={['tie-club-row', isWinnerB && 'winner']}>
              <div class="tie-club-identity">
                <span class:list={['club-flag-icon', flag(seedB?.country)]} aria-hidden="true"></span>
                <span class="tie-club-name">{seedB?.name || tie.clubBId}</span>
                <span class="tie-entry-badge">{entryLabel(seedB?.entryType || 'base')}</span>
              </div>
              <div class="tie-club-match">
                {wcB?.status === 'ok' ? (
                  <span class="tie-match-detail">
                    {wcB.goalsFor}-{wcB.goalsAgainst}
                    <span class="tie-ha">{wcB.homeAway === 'home' ? 'LOCAL' : 'VISITA'}</span>
                    vs {wcB.opponent}
                    <span class="tie-match-comp">{wcB.competition} · {wcB.sourceDate}</span>
                    {(wcB.yellowCards !== null && wcB.yellowCards !== undefined) && (
                      <span class="tie-cards">
                        {wcB.yellowCards > 0 && <span class="card card-yellow" title="Amarillas">🟨 {wcB.yellowCards}</span>}
                        {wcB.redCards > 0 && <span class="card card-red" title="Rojas">🟥 {wcB.redCards}</span>}
                      </span>
                    )}
                  </span>
                ) : (
                  <span class="tie-no-match">sin partido en ventana</span>
                )}
              </div>
              <div class="tie-breakdown">{scoreBreakdownText(wcB)}</div>
              <div class="tie-score-chip" data-winner={isWinnerB ? 'true' : 'false'}>
                {tie.scoreB}
              </div>
            </div>

            <footer class="tie-article-footer">
              Clasifica: <strong>
                {tie.winnerClubId === tie.clubAId ? (seedA?.name || tie.clubAId) : (seedB?.name || tie.clubBId)}
              </strong>
            </footer>
          </article>
        ))}
      </div>
    </section>

    <!-- FASE DE GRUPOS -->
    <section class="block" id="grupos">
      <h2>Fase de grupos</h2>
      <p class="criterion-note">
        32 clubes (11 directos + 21 ganadores de previa) en <strong>8 grupos de 4</strong>.
        El puntaje es <strong>acumulación pura</strong>: cada fecha abre una ventana de ~14 días
        en la que cada club juega <strong>2 partidos reales</strong> de su agenda local.
        Ambos suman al total fantasy — sin enfrentamiento directo entre clubes del grupo.
      </p>

      <!-- FECHAS TEMPLATE -->
      <h3 class="subsection-title">Calendario de fechas</h3>
      <div class="fechas-grid">
        {roundWindows.map((rw: any, i: number) => (
          <div class="fecha-card">
            <div class="fecha-label">F{i + 1}</div>
            <div class="fecha-body">
              <strong>{rw.roundId}</strong>
              <span class="fecha-range">
                {new Date(rw.windowStart).toLocaleDateString('es-AR', { day: 'numeric', month: 'long' })}
                {' – '}
                {new Date(rw.windowEnd).toLocaleDateString('es-AR', { day: 'numeric', month: 'long' })}
              </span>
              <small class="fecha-ext">ext. hasta {new Date(rw.extendedWindowEnd).toLocaleDateString('es-AR', { day: 'numeric', month: 'long' })}</small>
              <span class:list={['fecha-status', rw.fantasyScores?.length > 0 ? 'status-done' : 'status-pending']}>
                {rw.fantasyScores?.length > 0 ? 'Jugada' : 'Pendiente'}
              </span>
            </div>
          </div>
        ))}
      </div>

      <!-- CLASIFICACIÓN -->
      <h3 class="subsection-title">Clasificación</h3>
      <div class="class-table">
        <div class="class-row class-direct">
          <span class="class-pos">1° y 2°</span>
          <span class="class-desc">Avanzan directamente a la fase eliminatoria</span>
        </div>
        <div class="class-row class-playoff">
          <span class="class-pos">3°</span>
          <span class="class-desc">
            Playoff de repechaje vs. tercero de grupo de Copa Sudamericana
            <span class="tbd-badge">Copa Sud TBD</span>
          </span>
        </div>
        <div class="class-row class-out">
          <span class="class-pos">4°</span>
          <span class="class-desc">Eliminado del torneo</span>
        </div>
      </div>

      <!-- SORTEO -->
      <h3 class="subsection-title">Sorteo oficial 2026</h3>
      <p class="criterion-note">
        Sorteo dirigido sin clubes del mismo país en el mismo grupo. Danubio*
        provisional pendiente cierre de la llave PT-12.
      </p>
      <div class="groups-draw-grid">
        {groups.map((group: any) => (
          <article class="group-draw-card">
            <h4 class="group-draw-title">Grupo {group.group}</h4>
            <ul class="group-draw-list">
              {group.clubIds.map((id: string) => {
                const s = seedByIdWiki.get(id);
                const name = s?.name || id;
                const country = s?.country || '--';
                const accent = getClubAccentColor(id);
                const isProvisional = id === 'uy-danubio';
                return (
                  <li class:list={['group-draw-club', 'club-accent', isProvisional && 'provisional']} style={`--club-accent:${accent}`}>
                    <span class:list={['club-flag-icon', flag(country)]} aria-hidden="true"></span>
                    <span>{name}</span>
                    {isProvisional && <span class="prov-star" title="Provisional — PT-12 pendiente">*</span>}
                  </li>
                );
              })}
            </ul>
          </article>
        ))}
      </div>

      <p class="criterion-note footnote">
        * Danubio lidera PT-12 (5 pts vs General Caballero TBD). El grupo F se actualiza si el resultado cambia el ganador. ·
        Los 8 cupos de Copa Sudamericana para el playoff de 3ros se conocerán al finalizar esa fase de grupos.
      </p>
    </section>

  </main>
</Layout>


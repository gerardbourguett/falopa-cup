---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import { SITE_TITLE } from '../../consts';
import {
  getClubAccentColor,
  getEntryTypeSportLabel,
} from '../../lib/tournaments/conference-league-sudamericana/club-visuals';

const entries = await getCollection('conference-league-sudamericana');

const clubsDoc = entries.find((entry) => entry.data.kind === 'clubs')?.data as any;
const stageDoc = entries.find((entry) => entry.data.kind === 'stage')?.data as any;
const groupsDoc = entries.find((entry) => entry.data.kind === 'groups')?.data as any;
const windowCutDoc = entries.find((entry) => entry.data.kind === 'window-cut')?.data as any;

const seedById = new Map<string, any>(
  (clubsDoc?.seeds || []).map((seed: any) => [seed.clubId, seed] as [string, any])
);

const countryNames: Record<string, string> = {
  AR: 'Argentina',
  BO: 'Bolivia',
  BR: 'Brasil',
  CL: 'Chile',
  CO: 'Colombia',
  EC: 'Ecuador',
  PY: 'Paraguay',
  PE: 'Perú',
  UY: 'Uruguay',
  VE: 'Venezuela',
};

function flagClass(country: string) {
  return `fi fi-${String(country || '').toLowerCase()}`;
}

function getSeed(clubId: string) {
  return seedById.get(clubId);
}

function allocationLabel(category?: string) {
  switch (category) {
    case 'league-direct': return 'Directo por cupo país';
    case 'coefficient-direct': return 'Directo por coeficiente';
    case 'preliminary-pot-1': return 'Bombo 1 por coeficiente';
    case 'preliminary-pot-2': return 'Bombo 2 por coeficiente';
    default: return 'Sin categoría editorial';
  }
}

function clubMeta(clubId: string) {
  const seed = getSeed(clubId);
  const country = seed?.country || '--';
  return {
    clubId,
    name: seed?.name || clubId,
    country,
    countryName: countryNames[country] || country,
    accent: getClubAccentColor(clubId),
    entryType: seed?.entryType || 'base',
    entryTypeLabel: getEntryTypeSportLabel(seed?.entryType),
    coefficient: seed?.conmebolCoefficient ?? null,
    coefficientLabel: seed?.coefficientLabel || 'SR',
    allocationCategory: seed?.allocationCategory,
    allocationLabel: allocationLabel(seed?.allocationCategory),
  };
}

const preliminaryTies = stageDoc?.preliminaryTies || [];

const preliminaryPotAIds = stageDoc?.preliminaryPot1Ids || [];
const preliminaryPotBIds = stageDoc?.preliminaryPot2Ids || [];
const preliminaryPotA = preliminaryPotAIds.map((clubId: string) => clubMeta(clubId));
const preliminaryPotB = preliminaryPotBIds.map((clubId: string) => clubMeta(clubId));
const potASet = new Set(preliminaryPotA.map((club: any) => club.clubId));
const potBSet = new Set(preliminaryPotB.map((club: any) => club.clubId));

function potLabel(clubId: string) {
  if (potASet.has(clubId)) return 'B1';
  if (potBSet.has(clubId)) return 'B2';
  return '—';
}

const tieCards = preliminaryTies.map((tie: any) => {
  const clubA = clubMeta(tie.clubAId);
  const clubB = clubMeta(tie.clubBId);
  const hasScore = Number.isFinite(tie.scoreA) && Number.isFinite(tie.scoreB);
  const winnerName =
    tie.winnerClubId === tie.clubAId ? clubA.name
    : tie.winnerClubId === tie.clubBId ? clubB.name
    : null;
  return {
    ...tie,
    clubA,
    clubB,
    potA: potLabel(tie.clubAId),
    potB: potLabel(tie.clubBId),
    hasScore,
    scoreLabel: hasScore ? `${tie.scoreA}–${tie.scoreB}` : '—',
    winnerName,
  };
});

// Groups data
const groups = groupsDoc?.groups || [];
const roundWindows: any[] = groupsDoc?.roundWindows || [];
// Build fantasy breakdown per club from all round scores
const fantasyByClub = new Map<string, { played: number; base: number; bonus: number; penalty: number; total: number }>();
for (const rw of roundWindows) {
  for (const fs of (rw.fantasyScores || [])) {
    const prev = fantasyByClub.get(fs.clubId) || { played: 0, base: 0, bonus: 0, penalty: 0, total: 0 };
    prev.played++;
    prev.base += fs.basePoints;
    prev.bonus += fs.bonusPoints;
    prev.penalty += fs.penaltyPoints;
    prev.total += fs.total;
    fantasyByClub.set(fs.clubId, prev);
  }
}

// Build fantasy standings by group, sorted by total desc
const fantasyStandingsByGroup = new Map<string, any[]>();
for (const group of groups) {
  const rows = group.clubIds.map((id: string) => {
    const fb = fantasyByClub.get(id) || { played: 0, base: 0, bonus: 0, penalty: 0, total: 0 };
    return { ...clubMeta(id), clubId: id, ...fb };
  });
  rows.sort((a: any, b: any) => b.total - a.total || b.bonus - a.bonus || b.base - a.base);
  fantasyStandingsByGroup.set(group.group, rows);
}

// Fantasy score lookup: roundId -> clubId -> score entry
const roundScoreMap = new Map<string, Map<string, any>>();
for (const rw of roundWindows) {
  const m = new Map<string, any>();
  for (const fs of (rw.fantasyScores || [])) {
    m.set(fs.clubId, fs);
  }
  roundScoreMap.set(rw.roundId, m);
}

// Match sources lookup: roundId -> clubId -> match source entries
const matchSourceMap = new Map<string, Map<string, any[]>>();
for (const rw of roundWindows) {
  const m = new Map<string, any[]>();
  for (const ms of (rw.windowMatchSources || [])) {
    if (!m.has(ms.clubId)) m.set(ms.clubId, []);
    m.get(ms.clubId)!.push(ms);
  }
  matchSourceMap.set(rw.roundId, m);
}

// Audit data
const windowCutRows = (windowCutDoc?.entries || []).map((entry: any) => ({
  ...entry,
  ...clubMeta(entry.clubId),
}));

const windowCutRanking = [...windowCutRows]
  .filter((entry: any) => entry.status === 'ok')
  .sort((a: any, b: any) => {
    if (b.total !== a.total) return b.total - a.total;
    if ((b.gd ?? -999) !== (a.gd ?? -999)) return (b.gd ?? -999) - (a.gd ?? -999);
    if ((b.gf ?? -999) !== (a.gf ?? -999)) return (b.gf ?? -999) - (a.gf ?? -999);
    return String(a.sourceDate || '').localeCompare(String(b.sourceDate || ''));
  });

const windowCutNoMatch = windowCutRows.filter((entry: any) => entry.status === 'no-match');

function fantasyBreakdown(entry: any) {
  if (entry.status !== 'ok') return { base: 0, bonus: 0, penalty: 0, total: 0, text: 'Sin partido oficial (no-match) ⇒ 0' };
  const goalsFor = Number(entry.goalsFor ?? 0);
  const goalsAgainst = Number(entry.goalsAgainst ?? 0);
  const isWin = goalsFor > goalsAgainst;
  const isDraw = goalsFor === goalsAgainst;
  const isLoss = goalsFor < goalsAgainst;
  const base = isWin ? 3 : isDraw ? 1 : 0;
  const cleanSheet = goalsAgainst === 0 ? 1 : 0;
  const margin = isWin ? Math.max(0, (goalsFor - goalsAgainst) - 1) : 0;
  const bonus = cleanSheet + margin;
  const wideLoss = isLoss && goalsAgainst - goalsFor >= 3 ? -1 : 0;
  const yellowPenalty = -(Number(entry.yellowCards ?? 0) * 0.25);
  const redPenalty = -(Number(entry.redCards ?? 0));
  const penalty = wideLoss + yellowPenalty + redPenalty;
  const total = base + bonus + penalty;
  const chunks: string[] = [`base ${base} (${isWin ? 'victoria' : isDraw ? 'empate' : 'derrota'})`];
  if (cleanSheet) chunks.push('+1 arco en cero');
  if (margin) chunks.push(`+${margin} margen`);
  if (wideLoss) chunks.push('-1 derrota amplia');
  if (yellowPenalty < 0) chunks.push(`${yellowPenalty} amarillas`);
  if (redPenalty < 0) chunks.push(`${redPenalty} rojas`);
  chunks.push(`= ${total}`);
  return { base, bonus, penalty, total, text: chunks.join(' · ') };
}

function cardDeductions(entry: any): number | null {
  if (entry?.yellowCards === null || entry?.yellowCards === undefined) return null;
  if (entry?.redCards === null || entry?.redCards === undefined) return null;
  return Number(entry.yellowCards) * 0.25 + Number(entry.redCards);
}

const windowCutWithFantasy = windowCutRows.map((entry: any) => ({ ...entry, fantasy: fantasyBreakdown(entry) }));
const windowCutByClubId = new Map<string, any>(
  windowCutWithFantasy.map((entry: any) => [entry.clubId, entry] as [string, any])
);

function tieResolutionDetail(tie: any) {
  const a = windowCutByClubId.get(tie.clubAId);
  const b = windowCutByClubId.get(tie.clubBId);
  if (!a || !b) return 'Sin datos de ventana';
  if (a.total !== b.total) return 'Desempate: total fantasy';
  const deductA = cardDeductions(a);
  const deductB = cardDeductions(b);
  if (deductA !== null && deductB !== null && deductA !== deductB) return 'Desempate: menos tarjetas';
  if ((a.gf ?? -999) !== (b.gf ?? -999)) return 'Desempate: goles marcados';
  const awayA = a.homeAway === 'away';
  const awayB = b.homeAway === 'away';
  if (awayA !== awayB) return 'Desempate: condición visita';
  return 'Desempate: criterio administrativo';
}

const preliminaryWikiRows = tieCards.map((tie: any) => ({
  ...tie,
  sourceA: windowCutByClubId.get(tie.clubAId),
  sourceB: windowCutByClubId.get(tie.clubBId),
  resolutionDetail: tieResolutionDetail(tie),
}));

const reviewNoMatch = windowCutWithFantasy.filter((e: any) => e.status === 'no-match');
const reviewNonEspn = windowCutWithFantasy.filter((e: any) => e.status === 'ok' && e.sourceUrl && !String(e.sourceUrl).includes('espn.com'));
const reviewAdministrativeTies = preliminaryWikiRows.filter((t: any) => t.resolvedBy === 'administrative');
const reviewMissingCards = windowCutWithFantasy.filter((e: any) => e.status === 'ok' && (e.yellowCards === null || e.yellowCards === undefined || e.redCards === null || e.redCards === undefined));
---

<Layout
  title={`Conference League Sudamericana — ${SITE_TITLE}`}
  description="Torneo fantasy por ventanas: edición 2026"
  currentPath="/conference-league-sudamericana"
>
  <section class="page-hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <p class="eyebrow">Conference League Sudamericana</p>
        <h1>Fase de Grupos <span class="hero-year">2026</span></h1>
        <p class="hero-sub">32 clubes · 8 grupos · 3 fechas fantasy · Acumulación pura</p>
      </div>
      <div class="hero-stat-bar">
        <div class="hero-stat"><span class="hero-stat-num">{clubsDoc?.seeds?.length || 0}</span><span class="hero-stat-label">Participantes</span></div>
        <div class="hero-stat"><span class="hero-stat-num">{stageDoc?.mainStageQualifiedIds?.length || 0}</span><span class="hero-stat-label">Clasificados</span></div>
        <div class="hero-stat"><span class="hero-stat-num">3</span><span class="hero-stat-label">Fechas</span></div>
        <div class="hero-stat"><span class="hero-stat-num">6</span><span class="hero-stat-label">Partidos/club</span></div>
      </div>
    </div>
  </section>

  <div class="container page-nav-strip">
    <a href="/conference-league-sudamericana/wiki" class="page-nav-tab">Wiki</a>
    <a href="/conference-league-sudamericana" class="page-nav-tab active" aria-current="page">Resultados</a>
  </div>

  <main class="container page-main">

    <!-- ===== FASE DE GRUPOS ===== -->
    <section class="block block-groups">
      <div class="section-header">
        <h2>Fase de Grupos</h2>
        <span class="section-badge">
          {roundWindows.length > 0 ? `${roundWindows.length} ronda${roundWindows.length > 1 ? 's' : ''} jugada${roundWindows.length > 1 ? 's' : ''}` : 'Pendiente de inicio'}
        </span>
      </div>

      {roundWindows.length > 0 && (
        <div class="round-tabs">
          {roundWindows.map((rw: any) => (
            <span class="round-tab active">{rw.roundId} · {rw.windowStart} – {rw.windowEnd}</span>
          ))}
        </div>
      )}

      <div class="groups-grid">
        {groups.map((group: any) => {
          const standings = fantasyStandingsByGroup.get(group.group) || group.clubIds.map((id: string) => ({ ...clubMeta(id), clubId: id, played: 0, base: 0, bonus: 0, penalty: 0, total: 0 }));
          return (
            <article class="group-card" data-group={group.group}>
              <h3 class="group-title">Grupo {group.group}</h3>
              <table class="standings-table">
                <thead>
                  <tr>
                    <th class="col-pos">#</th>
                    <th class="col-club">Club</th>
                    <th title="Partidos jugados">PJ</th>
                    <th title="Base: V(3) E(1) D(0)">Base</th>
                    <th title="Bonus: Arco en cero + Margen progresivo" class="col-bonus">+B</th>
                    <th title="Penal: Derrota amplia + Tarjetas" class="col-penal">−P</th>
                    <th title="Fantasy total acumulado" class="col-fx">FX</th>
                  </tr>
                </thead>
                <tbody>
                  {standings.map((row: any, idx: number) => {
                    const isLeader = idx === 0 && row.played > 0;
                    return (
                      <tr class:list={[isLeader && 'row-leader']}>
                        <td class="col-pos">{idx + 1}</td>
                        <td class="col-club">
                          <span class="inline-club club-accent" style={`--club-accent:${row.accent}`}>
                            <span class:list={['club-flag-icon', flagClass(row.country)]} aria-hidden="true"></span>
                            <span class="club-name-text">{row.name}</span>
                          </span>
                        </td>
                        <td>{row.played}</td>
                        <td>{row.base}</td>
                        <td class="col-bonus">{row.bonus > 0 ? `+${row.bonus}` : row.bonus}</td>
                        <td class="col-penal">{row.penalty < 0 ? row.penalty : row.penalty}</td>
                        <td class:list={['col-fx', row.total > 0 ? 'fx-pos' : row.total < 0 ? 'fx-neg' : '']}>{row.total}</td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
              <div class="standings-legend">
                <span title="Victoria 3 · Empate 1 · Derrota 0">Base: V3 E1 D0</span>
                <span title="Arco en cero (+1) + Margen progresivo (+N−1)">+B: AEC + Margen</span>
                <span title="Derrota amplia (−1) + Amarillas (−0.25) + Rojas (−1)">−P: DA + Tarj</span>
              </div>
              {roundWindows.length > 0 && (
                <div class="match-sources">
                  {standings.map((row: any) => {
                    const allMatches = roundWindows.flatMap((rw: any) =>
                      (matchSourceMap.get(rw.roundId)?.get(row.clubId) || []).map((ms: any) => ({ ...ms, roundLabel: rw.roundId.replace('GS-', '') }))
                    );
                    return (
                      <div class="ms-club-row">
                        <span class="ms-club-name">
                          <span class:list={['club-flag-icon', flagClass(row.country)]} aria-hidden="true"></span>
                          {row.name}
                        </span>
                        <div class="ms-matches">
                          {allMatches.length > 0 ? allMatches.map((ms: any) => (
                            <span class:list={['ms-match', ms.counted ? 'ms-counted' : 'ms-not-counted']}>
                              {ms.goalsFor}–{ms.goalsAgainst}
                              <small>{ms.isHome ? 'L' : 'V'} · {ms.roundLabel}</small>
                            </span>
                          )) : (
                            <span class="ms-pending">sin partidos cargados</span>
                          )}
                        </div>
                      </div>
                    );
                  })}
                </div>
              )}
            </article>
          );
        })}
      </div>
    </section>

    <!-- ===== FASE PREVIA — RESULTADOS ===== -->
    <section class="block">
      <div class="section-header">
        <h2>Fase Previa — Resultados</h2>
        <span class="section-badge">{tieCards.filter((t: any) => t.hasScore).length}/{tieCards.length} resueltas</span>
      </div>
      <div class="ties-grid">
        {tieCards.map((tie: any) => (
          <article class="tie-card">
            <header class="tie-header">
              <span class="tie-id">{tie.id}</span>
              <div class="tie-result">
                {tie.hasScore ? (
                  <>
                    <span class="tie-score">{tie.scoreLabel}</span>
                    <small class="tie-winner">{tie.winnerName ? `→ ${tie.winnerName}` : ''}</small>
                  </>
                ) : <span class="tie-pending">pendiente</span>}
              </div>
            </header>

            <div class:list={['tie-club', 'club-accent', tie.winnerClubId === tie.clubAId && 'winner']} style={`--club-accent:${tie.clubA.accent}`}>
              <div class="tie-club-main">
                <span class:list={['club-flag-icon', flagClass(tie.clubA.country)]} aria-hidden="true"></span>
                <span>{tie.clubA.name}</span>
              </div>
              <small>{tie.potA} · {tie.clubA.coefficientLabel}</small>
            </div>

            <div class:list={['tie-club', 'club-accent', tie.winnerClubId === tie.clubBId && 'winner']} style={`--club-accent:${tie.clubB.accent}`}>
              <div class="tie-club-main">
                <span class:list={['club-flag-icon', flagClass(tie.clubB.country)]} aria-hidden="true"></span>
                <span>{tie.clubB.name}</span>
              </div>
              <small>{tie.potB} · {tie.clubB.coefficientLabel}</small>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ===== AUDITORÍA (colapsada) ===== -->
    <details class="audit-block">
      <summary>Auditoría — Ventana de corte para sorteo de grupos</summary>
      <div class="audit-body">
        <p class="criterion-note">
          Ventana: <strong>{windowCutDoc?.windowStart || '—'}</strong> a <strong>{windowCutDoc?.windowEnd || '—'}</strong>.
        </p>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>#</th><th>Bombo</th><th>Club</th><th>Total</th><th>Partido</th><th>Src</th>
              </tr>
            </thead>
            <tbody>
              {windowCutRanking.map((row: any, index: number) => (
                <tr>
                  <td>{index + 1}</td>
                  <td>{row.pot}</td>
                  <td>
                    <span class="inline-club">
                      <span class:list={['club-flag-icon', flagClass(row.country)]} aria-hidden="true"></span>
                      <span>{row.name}</span>
                    </span>
                  </td>
                  <td>{row.total}</td>
                  <td>
                    {row.goalsFor}-{row.goalsAgainst} ({row.homeAway === 'home' ? 'L' : 'V'}) vs {row.opponent}
                    <br /><small>{row.competition} · {row.sourceDate}</small>
                  </td>
                  <td>{row.sourceUrl ? <a href={row.sourceUrl} target="_blank" rel="noreferrer">link</a> : '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        {windowCutNoMatch.length > 0 && (
          <p class="criterion-note" style="margin-top:0.75rem">
            <strong>Sin partido en ventana:</strong> {windowCutNoMatch.map((e: any) => e.name).join(', ')}
          </p>
        )}
      </div>
    </details>

    <details class="audit-block">
      <summary>Auditoría — Acta fantasy por club (previa)</summary>
      <div class="audit-body">
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Club</th><th>B</th><th>Partido fuente</th><th>Tarjetas</th><th>Desglose</th><th>Total</th><th>Src</th>
              </tr>
            </thead>
            <tbody>
              {windowCutWithFantasy
                .sort((a: any, b: any) => a.name.localeCompare(b.name))
                .map((row: any) => (
                  <tr>
                    <td>
                      <span class="inline-club">
                        <span class:list={['club-flag-icon', flagClass(row.country)]} aria-hidden="true"></span>
                        <span>{row.name}</span>
                      </span>
                    </td>
                    <td>{row.pot}</td>
                    <td>
                      {row.status === 'ok' ? (
                        <>
                          {row.goalsFor}-{row.goalsAgainst} ({row.homeAway === 'home' ? 'L' : 'V'}) vs {row.opponent}
                          <br /><small>{row.competition} · {row.sourceDate}</small>
                        </>
                      ) : 'Sin partido'}
                    </td>
                    <td>
                      {row.status === 'ok' ? (
                        row.yellowCards === null || row.yellowCards === undefined
                          ? 'Pendiente'
                          : `A:${row.yellowCards} R:${row.redCards}`
                      ) : '—'}
                    </td>
                    <td><small>{row.fantasy.text}</small></td>
                    <td><strong>{row.fantasy.total}</strong></td>
                    <td>{row.sourceUrl ? <a href={row.sourceUrl} target="_blank" rel="noreferrer">link</a> : '—'}</td>
                  </tr>
                ))}
            </tbody>
          </table>
        </div>
      </div>
    </details>

    <details class="audit-block">
      <summary>Auditoría — Acta de llaves (resolución fantasy)</summary>
      <div class="audit-body">
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Llave</th><th>Club A</th><th>Club B</th><th>Marcador</th><th>Tarjetas A/B</th><th>Resolución</th><th>Ganador</th>
              </tr>
            </thead>
            <tbody>
              {preliminaryWikiRows.map((tie: any) => (
                <tr>
                  <td>{tie.id}</td>
                  <td>
                    <strong>{tie.clubA.name}</strong>
                    <br /><small>{tie.sourceA?.fantasy?.text || 'Sin datos'}</small>
                  </td>
                  <td>
                    <strong>{tie.clubB.name}</strong>
                    <br /><small>{tie.sourceB?.fantasy?.text || 'Sin datos'}</small>
                  </td>
                  <td><strong>{tie.scoreLabel}</strong></td>
                  <td>{cardDeductions(tie.sourceA) ?? '—'} / {cardDeductions(tie.sourceB) ?? '—'}</td>
                  <td>{tie.resolutionDetail}</td>
                  <td>{tie.winnerName || '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </details>

    <details class="audit-block">
      <summary>Auditoría — Pendientes de revisión manual</summary>
      <div class="audit-body">
        <ul class="audit-list">
          <li><strong>Sin partido en ventana:</strong> {reviewNoMatch.length ? reviewNoMatch.map((e: any) => e.name).join(', ') : 'ninguno'}</li>
          <li><strong>Fuentes fuera de ESPN:</strong> {reviewNonEspn.length ? reviewNonEspn.map((e: any) => e.name).join(', ') : 'ninguna'}</li>
          <li><strong>Llaves en criterio administrativo:</strong> {reviewAdministrativeTies.length ? reviewAdministrativeTies.map((t: any) => t.id).join(', ') : 'ninguna'}</li>
          <li><strong>Clubes sin tarjetas cargadas:</strong> {reviewMissingCards.length ? reviewMissingCards.map((e: any) => e.name).join(', ') : 'ninguno'}</li>
        </ul>
      </div>
    </details>

  </main>
</Layout>

<style>
  /* ═══════════════════════════════════════════
     CONFERENCE LEAGUE · BROADCAST EDITORIAL
     ═══════════════════════════════════════════ */

  /* ── Hero: broadcast lower-third style ── */
  .page-hero {
    background: #000;
    padding: 0;
    border-bottom: none;
    position: relative;
    overflow: hidden;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 1px,
        rgba(29, 185, 84, 0.03) 1px,
        rgba(29, 185, 84, 0.03) 2px
      );
    pointer-events: none;
  }

  .page-hero::after {
    content: 'CLS';
    position: absolute;
    right: -0.5rem;

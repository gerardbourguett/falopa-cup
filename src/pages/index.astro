---
import Layout from "../components/Layout.astro";
import { Hero } from "../components/Hero";
import { ChampionCard } from "../components/ChampionCard";
import HolderChain from "../components/HolderChain.astro";
import styles from "./_index.module.css";
import { getCollection } from "astro:content";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCurrentHolder, getCurrentReign, getHolderChain } from "../lib/tournament";

const falopaCupEntries = await getCollection("falopa-cup");
const copaPabloMiladEntries = await getCollection("copa-pablo-milad");
const clubsEntries = await getCollection("clubs");

const clubById = new Map(clubsEntries.map((e) => [e.data.id || e.id, e.data]));

const latestFalopa = falopaCupEntries.sort(
  (a, b) => b.data.year - a.data.year,
)[0];
const latestMilad = copaPabloMiladEntries.sort(
  (a, b) => b.data.year - a.data.year,
)[0];

const falopaHolder = latestFalopa
  ? getCurrentHolder(latestFalopa.data.matches)
  : null;
const miladHolder = latestMilad
  ? getCurrentHolder(latestMilad.data.matches)
  : null;
const falopaReign = latestFalopa
  ? getCurrentReign(latestFalopa.data.matches)
  : null;
const miladReign = latestMilad
  ? getCurrentReign(latestMilad.data.matches)
  : null;

function getClub(id?: string) {
  return id ? clubById.get(id) : undefined;
}

const falopaClub = getClub(falopaHolder?.holderId);
const miladClub = getClub(miladHolder?.holderId);
const falopaYear = latestFalopa?.data.year ?? 2026;
const miladYear = latestMilad?.data.year ?? 2026;

// Holder chains for #concepto section (show last 5 entries max)
const falopaChain = latestFalopa ? getHolderChain(latestFalopa.data.matches) : [];
const miladChain = latestMilad ? getHolderChain(latestMilad.data.matches) : [];

function formatSinceDate(value?: string | Date | null) {
  if (!value) return "";
  const d = value instanceof Date ? value : new Date(value);
  return d.toLocaleDateString("es-CL", {
    day: "numeric",
    month: "short",
    year: "2-digit",
  });
}
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION} currentPath="/">
  <!-- Hero -->
  <Hero
    client:load
    title="FALOPA CUP"
    subtitle="Campeón No Oficial + Copa del Más Malo"
    description="Seguimos dos títulos itinerantes del fútbol chileno: el campeón no oficial y la copa del más malo. Inspirado en el Campeonato Mundial No Oficial."
    year={falopaYear}
  />

  <!-- Champions Section -->
  <section class={styles.championsSection}>
    <div class="container">
      <div class={styles.sectionHeader}>
        <span class={styles.sectionLabel}>POSEEEDORES ACTUALES</span>
      </div>

      <div class={styles.championsGrid}>
        <ChampionCard
          client:visible
          club={falopaClub || {
            name: "DESCONOCIDO",
            shortName: "N/A",
            logo: "",
          }}
          tournament="FALOPA CUP"
          year={falopaYear}
          sinceDate={formatSinceDate(falopaReign?.since)}
          accentColor="gold"
          href="/falopa-cup"
        />

        <ChampionCard
          client:visible
          club={miladClub || {
            name: "DESCONOCIDO",
            shortName: "N/A",
            logo: "",
          }}
          tournament="COPA PABLO MILAD"
          year={miladYear}
          sinceDate={formatSinceDate(miladReign?.since)}
          accentColor="burgundy"
          href="/copa-pablo-milad"
        />
      </div>
    </div>
  </section>

  <!-- Concepto Section -->
  <section id="concepto" class={styles.conceptSection}>
    <div class="container">
      <div class={styles.sectionHeader}>
        <span class={styles.sectionLabel}>EL CONCEPTO</span>
      </div>

      <div class={styles.conceptBody}>
        <div>
          <h2 class={styles.conceptTitle}>¿QUÉ ES UN CAMPEONATO ITINERANTE?</h2>
          <p class={styles.conceptDesc}>
            En el <a href="https://en.wikipedia.org/wiki/Unofficial_Football_World_Championships" target="_blank" rel="noopener" class={styles.conceptLink}>Campeonato Mundial No Oficial</a>, el título no se gana en un torneo: se toma en la cancha. El campeón lo defiende en cada partido, y si pierde, el título pasa al rival. Así el trofeo viaja de club en club a lo largo de la temporada.
            Nosotros aplicamos el mismo principio al fútbol chileno — cada jornada, alguien tiene algo más que tres puntos en juego.
          </p>
        </div>

        <div class={styles.conceptChains}>
          <div class={styles.conceptChainBlock}>
            <span class={styles.conceptChainLabel}>FALOPA CUP {falopaYear}</span>
            <HolderChain
              chain={falopaChain}
              clubs={clubById}
              accentColor="gold"
              maxVisible={5}
              compact={true}
            />
          </div>

          <div class={styles.conceptChainBlock}>
            <span class={styles.conceptChainLabel}>COPA PABLO MILAD {miladYear}</span>
            <HolderChain
              chain={miladChain}
              clubs={clubById}
              accentColor="burgundy"
              maxVisible={5}
              compact={true}
            />
          </div>
        </div>

        <p class={styles.conceptCaption}>Cadena de poseedores · temporada {falopaYear}</p>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class={styles.rulesSection}>
    <div class="container">
      <div class={styles.sectionHeader}>
        <span class={styles.sectionLabel}>COMO FUNCIONA</span>
      </div>

      <div class={styles.rulesGrid}>
        <div class={styles.ruleCard}>
          <div class={styles.ruleNumber}>[01]</div>
          <h3 class={styles.ruleTitle}>FALOPA CUP</h3>
          <p class={styles.ruleText}>
            El título se defiende en <strong>cada partido oficial</strong>. Si
            el defensor pierde, el título cambia de manos.
          </p>
        </div>

        <div class={styles.ruleCard}>
          <div class={styles.ruleNumber}>[02]</div>
          <h3 class={styles.ruleTitle}>COPA PABLO MILAD</h3>
          <p class={styles.ruleText}>
            El título que nadie quiere: la copa <strong
              >solo cambia si el defensor gana</strong
            >. Si pierde o empata, lo conserva.
          </p>
        </div>

        <div class={styles.ruleCard}>
          <div class={styles.ruleNumber}>[03]</div>
          <h3 class={styles.ruleTitle}>NUEVA TEMPORADA</h3>
          <p class={styles.ruleText}>
            Cada año comienza con el <strong>campeón del Torneo Nacional</strong
            >
            como poseedor inicial de la Falopa Cup.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

---
import Layout from "../components/Layout.astro";
import { Hero } from "../components/Hero";
import { ChampionCard } from "../components/ChampionCard";
import HolderChain from "../components/HolderChain.astro";
import { getCollection } from "astro:content";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCurrentHolder, getHolderChain } from "../lib/tournament";

const falopaCupEntries = await getCollection("falopa-cup");
const copaPabloMiladEntries = await getCollection("copa-pablo-milad");
const clubsEntries = await getCollection("clubs");

const clubById = new Map(clubsEntries.map((e) => [e.data.id || e.id, e.data]));

const latestFalopa = falopaCupEntries.sort(
  (a, b) => b.data.year - a.data.year,
)[0];
const latestMilad = copaPabloMiladEntries.sort(
  (a, b) => b.data.year - a.data.year,
)[0];

const falopaHolder = latestFalopa
  ? getCurrentHolder(latestFalopa.data.matches)
  : null;
const miladHolder = latestMilad
  ? getCurrentHolder(latestMilad.data.matches)
  : null;

function getClub(id?: string) {
  return id ? clubById.get(id) : undefined;
}

const falopaClub = getClub(falopaHolder?.holderId);
const miladClub = getClub(miladHolder?.holderId);
const falopaYear = latestFalopa?.data.year ?? 2026;
const miladYear = latestMilad?.data.year ?? 2026;

// Holder chains for #concepto section (show last 5 entries max)
const falopaChain = latestFalopa ? getHolderChain(latestFalopa.data.matches) : [];
const miladChain = latestMilad ? getHolderChain(latestMilad.data.matches) : [];

function formatSinceDate(match: any) {
  if (!match?.date) return "";
  const d = match.date instanceof Date ? match.date : new Date(match.date);
  return d.toLocaleDateString("es-CL", {
    day: "numeric",
    month: "short",
    year: "2-digit",
  });
}
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION} currentPath="/">
  <!-- Hero -->
  <Hero
    client:load
    title="FALOPA CUP"
    subtitle="Campeón No Oficial + Copa del Más Malo"
    description="Seguimos dos títulos itinerantes del fútbol chileno: el campeón no oficial y la copa del más malo. Inspirado en el Campeonato Mundial No Oficial."
    year={falopaYear}
  />

  <!-- Champions Section -->
  <section class="champions-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">POSEEEDORES ACTUALES</span>
      </div>

      <div class="champions-grid">
        <ChampionCard
          client:visible
          club={falopaClub || {
            name: "DESCONOCIDO",
            shortName: "N/A",
            logo: "",
          }}
          tournament="FALOPA CUP"
          year={falopaYear}
          sinceDate={formatSinceDate(falopaHolder?.match)}
          accentColor="gold"
          href="/falopa-cup"
        />

        <ChampionCard
          client:visible
          club={miladClub || {
            name: "DESCONOCIDO",
            shortName: "N/A",
            logo: "",
          }}
          tournament="COPA PABLO MILAD"
          year={miladYear}
          sinceDate={formatSinceDate(miladHolder?.match)}
          accentColor="burgundy"
          href="/copa-pablo-milad"
        />
      </div>
    </div>
  </section>

  <!-- Concepto Section -->
  <section id="concepto" class="concepto-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">EL CONCEPTO</span>
      </div>

      <div class="concepto-body">
        <div class="concepto-text">
          <h2 class="concepto-title">¿QUÉ ES UN CAMPEONATO ITINERANTE?</h2>
          <p class="concepto-desc">
            En el <a href="https://en.wikipedia.org/wiki/Unofficial_Football_World_Championships" target="_blank" rel="noopener" class="concepto-link">Campeonato Mundial No Oficial</a>, el título no se gana en un torneo: se toma en la cancha. El campeón lo defiende en cada partido, y si pierde, el título pasa al rival. Así el trofeo viaja de club en club a lo largo de la temporada.
            Nosotros aplicamos el mismo principio al fútbol chileno — cada jornada, alguien tiene algo más que tres puntos en juego.
          </p>
        </div>

        <div class="concepto-chains">
          <div class="concepto-chain-block">
            <span class="concepto-chain-label">FALOPA CUP {falopaYear}</span>
            <HolderChain
              chain={falopaChain}
              clubs={clubById}
              accentColor="gold"
              maxVisible={5}
              compact={true}
            />
          </div>

          <div class="concepto-chain-block">
            <span class="concepto-chain-label">COPA PABLO MILAD {miladYear}</span>
            <HolderChain
              chain={miladChain}
              clubs={clubById}
              accentColor="burgundy"
              maxVisible={5}
              compact={true}
            />
          </div>
        </div>

        <p class="concepto-caption">Cadena de poseedores · temporada {falopaYear}</p>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="rules-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">COMO FUNCIONA</span>
      </div>

      <div class="rules-grid">
        <div class="rule-card">
          <div class="rule-number">[01]</div>
          <h3 class="rule-title">FALOPA CUP</h3>
          <p class="rule-text">
            El título se defiende en <strong>cada partido oficial</strong>. Si
            el defensor pierde, el título cambia de manos.
          </p>
        </div>

        <div class="rule-card">
          <div class="rule-number">[02]</div>
          <h3 class="rule-title">COPA PABLO MILAD</h3>
          <p class="rule-text">
            El título que nadie quiere: la copa <strong
              >solo cambia si el defensor gana</strong
            >. Si pierde o empata, lo conserva.
          </p>
        </div>

        <div class="rule-card">
          <div class="rule-number">[03]</div>
          <h3 class="rule-title">NUEVA TEMPORADA</h3>
          <p class="rule-text">
            Cada año comienza con el <strong>campeón del Torneo Nacional</strong
            >
            como poseedor inicial de la Falopa Cup.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .section {
    padding: 3rem 0;
  }

  .section-header {
    margin-bottom: 1.5rem;
  }

  .section-label {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: 0.1em;
  }

  .champions-section {
    background: var(--color-bg-primary);
    padding: 3rem 0;
  }

  .champions-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .champions-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Rules */
  .rules-section {
    background: var(--color-bg-secondary);
    border-top: 3px solid var(--color-bg-elevated);
    padding: 3rem 0;
  }

  .rules-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .rules-grid {
      grid-template-columns: 1fr;
    }
  }

  .rule-card {
    background: var(--color-bg-primary);
    border: 2px solid var(--color-bg-elevated);
    padding: 1.25rem;
  }

  .rule-number {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-liga-primera);
    margin-bottom: 0.75rem;
  }

  .rule-title {
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
    color: var(--color-text-primary);
    letter-spacing: 0.1em;
  }

  .rule-text {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .rule-text strong {
    color: var(--color-liga-primera);
  }

  /* ── Concepto ── */
  .concepto-section {
    background: var(--color-bg-primary);
    border-top: 3px solid var(--color-bg-elevated);
    border-bottom: 3px solid var(--color-bg-elevated);
    padding: 3rem 0;
  }

  .concepto-body {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .concepto-title {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }

  .concepto-desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0;
    max-width: 680px;
  }

  .concepto-link {
    color: var(--color-liga-primera);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .concepto-link:hover {
    color: var(--color-liga-primera-dim);
  }

  .concepto-chains {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .concepto-chains {
      grid-template-columns: 1fr;
    }
  }

  .concepto-chain-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .concepto-chain-label {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .concepto-caption {
    font-family: var(--font-body);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin: -1rem 0 0 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
</style>
